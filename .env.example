# ─── Razorpay ────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use rzp_test_* keys for testing, rzp_live_* for production

RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx

# Same Key ID is also needed on the frontend (VITE_ prefix = exposed to browser)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx


# ─── Firebase (Phone OTP) ─────────────────────────────────────────────────────
# Get from: https://console.firebase.google.com
# → Your Project → Project Settings → Your Apps → Web App → Config

VITE_FIREBASE_API_KEY=AIzaSy_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
